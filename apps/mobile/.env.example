# Copy to .env and fill in from your Supabase project (Project Settings -> API).
# These are the SAME project the web app uses — only the publishable (anon) key
# and URL belong here. Never put the secret key in a mobile build.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_KEY
EXPO_PUBLIC_FLOCK_NAME=Flock
