# Supabase — copy to .env.local and fill in from your Supabase project settings
# (Project Settings -> API Keys). Or provision Supabase via the Vercel Marketplace,
# which injects these automatically. Never commit real values to this file.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Publishable (or legacy anon) key — used only for the browser-facing auth
# session (login, token refresh). Safe to expose; RLS is what protects data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_KEY

# Secret (or legacy service_role) key — server-only, bypasses RLS. Used by the
# app's data layer and the seed script. NEVER expose this in the browser.
SUPABASE_SECRET_KEY=YOUR_SECRET_KEY

# Shared secret the app sends to the notify-event Edge Function (see
# "Notifications (Telegram)" in README.md). Must match the NOTIFY_SECRET
# Edge Function secret (`supabase secrets set NOTIFY_SECRET=...`).
NOTIFY_SECRET=

# Display name for your farm, shown in the app chrome. Optional (default "Flock").
NEXT_PUBLIC_FLOCK_NAME=
